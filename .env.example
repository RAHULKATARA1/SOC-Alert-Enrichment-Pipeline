# ─── SOC Alert Enrichment Pipeline ─── Environment Variables ───
# Copy this file to .env and fill in your API keys.
# The pipeline runs in DEMO MODE if no keys are configured.

# VirusTotal (Required for live enrichment)
# Get free key: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# AbuseIPDB (Optional — IP reputation)
# Get free key: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# AlienVault OTX (Optional — threat intelligence)
# Get free key: https://otx.alienvault.com/api
ALIENVAULT_OTX_API_KEY=

# Slack Webhook (Optional — alert notifications)
# Create webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Optional Overrides ───
# VT_RATE_LIMIT=4
# ABUSEIPDB_RATE_LIMIT=60
# OTX_RATE_LIMIT=100
# LOG_LEVEL=INFO
